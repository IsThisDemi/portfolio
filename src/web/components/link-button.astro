---
import type { LinkButton } from '@/types/shared';
import Icon from './icon.astro';

export interface Props extends Omit<LinkButton, 'url'>, Omit<astroHTML.JSX.HTMLAttributes, 'slot'> {
  url?: LinkButton['url'];
  as?: 'a' | 'button';
}

const { name, icon, url, as, ...props } = Astro.props;
const Element = as || 'a';
---

<Element
  aria-label={name}
  href={url}
  target="_blank"
  data-tooltip={name}
  class="flex h-8 w-8 items-center justify-center rounded-sm border border-white/[0.08] bg-white/[0.03] text-gray-600 transition-all duration-200 hover:border-white/[0.16] hover:text-gray-200 hover:bg-white/[0.07] hover:-translate-y-px active:translate-y-px focus:outline-none focus:ring-1 focus:ring-primary-500 focus:ring-offset-1 focus:ring-offset-main"
  {...props}
>
  <Icon name={icon} size={15} />
</Element>
