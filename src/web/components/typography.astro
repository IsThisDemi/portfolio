---
type TypographyVariant = keyof typeof variantToElement;

const variantToElement = {
  'main-title': 'h1',
  'main-subtitle': 'h2',
  'section-title': 'h2',
  'section-subtitle': 'h3',
  'item-title': 'h3',
  'item-subtitle-primary': 'p',
  'item-subtitle-secondary': 'p',
  'tile-title': 'h4',
  'tile-subtitle': 'p',
  paragraph: 'p',
  label: 'span',
  value: 'span',
  skill: 'span',
  tag: 'div',
  button: 'div',
} as const;

export const variantToClassName: Record<TypographyVariant, string> /* tw */ = {
  'main-title': 'font-heading text-4xl sm:text-5xl font-bold text-gray-50 tracking-tight leading-none',
  'main-subtitle': 'font-sans text-base sm:text-lg font-normal text-gray-400',
  'section-title': 'font-heading text-xl font-bold text-gray-100 tracking-tight',
  'section-subtitle': 'font-heading text-base font-semibold text-gray-200 uppercase tracking-[0.08em]',
  'item-title': 'font-heading text-lg font-bold text-gray-100 tracking-tight',
  'item-subtitle-primary': 'font-mono text-sm font-medium leading-snug text-primary-500',
  'item-subtitle-secondary': 'font-mono text-xs font-normal text-gray-500 tracking-wide',
  'tile-title': 'font-sans text-sm font-medium text-gray-300',
  'tile-subtitle': 'font-sans text-sm font-normal text-gray-500',
  paragraph: 'font-sans text-sm leading-relaxed font-normal text-gray-400 sm:text-sm sm:leading-relaxed',
  label: 'font-mono text-xs font-medium text-gray-500 uppercase tracking-[0.1em]',
  value: 'font-sans text-sm font-normal text-gray-300',
  skill: 'font-sans text-sm font-medium text-gray-300',
  tag: 'font-mono text-xs font-medium tracking-wide text-gray-200',
  button: 'font-sans text-sm font-semibold text-black',
};

interface LinkProps {
  href?: string;
  target?: string;
  rel?: string;
  download?: string;
}

export interface Props extends Omit<astroHTML.JSX.HTMLAttributes, 'slot'>, LinkProps {
  as?: keyof JSX.IntrinsicElements;
  variant?: TypographyVariant;
}

const { variant = 'paragraph', as, class: className, ...props } = Astro.props;
const Element = as ?? variantToElement[variant];
---

<Element {...props} class:list={[variantToClassName[variant], className]}><slot /></Element>
