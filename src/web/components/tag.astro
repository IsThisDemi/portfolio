---
import type { Tag } from '@/types/shared';
import Icon from './icon.astro';
import Typography from './typography.astro';

export interface Props extends Tag {}

const { name, description, icon, iconColor, url } = Astro.props;

const className = /* tw */
  'flex h-8 w-fit items-center gap-x-2 rounded-full border border-white/10 bg-white/5 px-4 backdrop-blur-sm transition-colors duration-300';
const customProps = url
  ? ({
      href: url,
      as: 'a',
      target: '_blank',
      rel: 'noopener noreferrer',
      class: `${className} hover:bg-white/10 hover:border-white/20 hover:text-white`,
    } as const)
  : {
      class: className,
    };
---

<Typography variant="tag" data-tooltip={description} {...customProps}>
  {icon && <Icon name={icon} color={iconColor} size={16} />}
  {name}
</Typography>
