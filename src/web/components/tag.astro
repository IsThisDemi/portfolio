---
import type { Tag } from '@/types/shared';
import Icon from './icon.astro';
import Typography from './typography.astro';

export interface Props extends Tag {}

const { name, description, icon, iconColor, url } = Astro.props;

const className =
  /* tw */
  'flex h-6 w-fit items-center gap-x-1.5 rounded-sm border border-white/[0.08] bg-white/[0.03] px-2.5 font-mono text-[11px] text-gray-400 transition-all duration-200 hover:border-primary-500/35 hover:bg-primary-500/[0.07] hover:text-primary-400 hover:-translate-y-px cursor-default';
const customProps = url
  ? ({
      href: url,
      as: 'a',
      target: '_blank',
      rel: 'noopener noreferrer',
      class: className,
    } as const)
  : {
      class: className,
    };
---

<Typography variant="tag" data-tooltip={description} {...customProps}>
  {icon && (
    <Icon name={icon} color={iconColor} size={11} />
  )}
  {name}
</Typography>
