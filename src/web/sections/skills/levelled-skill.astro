---
import type { LevelledSkill } from '@/types/sections/skills-section.types';
import Icon from '@/web/components/icon.astro';
import SkillLevel from './skill-level.astro';

export interface Props extends LevelledSkill {}

const { url, icon, iconColor, name, level, description } = Astro.props;

const IconWrapper = url ? 'a' : 'div';
---

<div
  class="group flex flex-col gap-1.5 rounded-sm border border-white/[0.05] bg-white/[0.02] px-3 py-2.5 transition-colors duration-200 hover:border-white/[0.1] hover:bg-white/[0.04]"
  data-tooltip={description}
>
  <IconWrapper
    class="flex items-center gap-2"
    {...url && { href: url, target: '_blank', rel: 'noopener noreferrer' }}
  >
    {icon && <Icon name={icon} color={iconColor} size={14} class="opacity-70 group-hover:opacity-100 transition-opacity" />}
    <span class="font-sans text-xs font-medium text-gray-300 group-hover:text-gray-100 transition-colors">{name}</span>
  </IconWrapper>
  <SkillLevel skillLevel={level} />
</div>
