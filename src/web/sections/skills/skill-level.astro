---
import type { SkillLevel } from '@/types/sections/skills-section.types';

export interface Props {
  skillLevel: SkillLevel;
}

const { skillLevel } = Astro.props;

// ASCII block progress bar
const total = 5;
const filled = skillLevel;
const empty = total - filled;
const bar = '█'.repeat(filled) + '░'.repeat(empty);
const pct = Math.round((skillLevel / total) * 100);
---

<div class="flex items-center gap-2 font-mono">
  <span
    class="text-xs tracking-tight"
    style={`color: ${skillLevel >= 4 ? '#C8FF00' : skillLevel >= 3 ? '#A8A8A3' : '#666660'}`}
  >{bar}</span>
  <span class="text-[10px] text-gray-700">{pct}%</span>
</div>
